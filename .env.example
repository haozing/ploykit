# PloyKit environment template
# Copy this file to .env and fill in real values. Never commit .env.

NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

# Better Auth
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-here-use-openssl-rand-base64-32

# Plugin runtime secrets
# Generate with: openssl rand -base64 32
PLUGIN_SECRET_ENCRYPTION_KEY=replace-with-a-stable-32-byte-base64-or-long-random-secret
PLUGIN_FILE_SIGNING_SECRET=replace-with-a-stable-32-byte-base64-or-long-random-secret

# Database
DB_PROVIDER=supabase
DATABASE_URL=postgresql://postgres.xxxxx:your-password@aws-0-xx-xxxx-0.pooler.supabase.com:5432/postgres

# App defaults
DEFAULT_TENANT_SLUG=default
SUPPORTED_LANGUAGES=en,zh,ja,es,fr,de

# Feature gates
BILLING_ENABLED=false
BILLING_DEMO_API_ENABLED=false
FILE_STORAGE_ENABLED=false
FILE_STORAGE_DRIVER=local
FILE_STORAGE_LOCAL_ROOT=.data/blobs

# S3/R2-compatible file storage
# FILE_STORAGE_DRIVER=s3
# FILE_STORAGE_ENDPOINT=https://s3.us-east-1.amazonaws.com
# FILE_STORAGE_BUCKET=ploykit-files
# FILE_STORAGE_ACCESS_KEY_ID=your-access-key
# FILE_STORAGE_SECRET_ACCESS_KEY=your-secret-key
# FILE_STORAGE_REGION=us-east-1
# FILE_STORAGE_FORCE_PATH_STYLE=true
# FILE_STORAGE_PUBLIC_BASE_URL=https://cdn.example.com

# Stripe
STRIPE_SECRET_KEY=replace-with-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=replace-with-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=replace-with-stripe-webhook-secret
