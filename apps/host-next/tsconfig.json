{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": "../..",
    "incremental": true,
    "jsx": "preserve",
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["src/*"],
      "@host/*": ["apps/host-next/*"],
      "@ploykit/module-sdk": ["src/module-sdk/index.ts"],
      "@ploykit/module-sdk/*": ["src/module-sdk/*"],
      "@radix-ui/react-avatar": ["node_modules/@radix-ui/react-avatar/dist/index.d.mts"],
      "@radix-ui/react-dialog": ["node_modules/@radix-ui/react-dialog/dist/index.d.mts"],
      "@radix-ui/react-dropdown-menu": ["node_modules/@radix-ui/react-dropdown-menu/dist/index.d.mts"],
      "@radix-ui/react-select": ["node_modules/@radix-ui/react-select/dist/index.d.mts"],
      "@radix-ui/react-tabs": ["node_modules/@radix-ui/react-tabs/dist/index.d.mts"],
      "lucide-react": ["node_modules/lucide-react/dist/lucide-react.d.ts"],
      "react": ["node_modules/@types/react"],
      "react-dom": ["node_modules/@types/react-dom"],
      "react-dom/*": ["node_modules/@types/react-dom/*"],
      "react/*": ["node_modules/@types/react/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "../../src/**/*.ts",
    "../../modules/**/*.ts",
    "../../modules/**/*.tsx"
  ],
  "exclude": ["node_modules"]
}
