{
  "name": "ploykit",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/haozing/ploykit.git"
  },
  "bugs": {
    "url": "https://github.com/haozing/ploykit/issues"
  },
  "homepage": "https://github.com/haozing/ploykit#readme",
  "engines": {
    "node": ">=20.11 <23",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "concurrently -n \"next,watch\" -c \"blue,magenta\" \"npm:dev:next\" \"npm:dev:watch\"",
    "dev:next": "next dev --webpack",
    "dev:watch": "tsx scripts/watch-plugins.ts",
    "prebuild": "tsx scripts/generate-plugin-map.ts --check",
    "build": "next build --webpack",
    "postbuild": "tsx scripts/prepare-standalone-assets.ts",
    "start": "node .next/standalone/server.js",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run typecheck && npm run lint && npm run format:check",
    "verify": "npm run typecheck && npm run lint && npm run format:check && npm run deps:check && npm run plugins:check && npm run plugins:templates && npm run test:run",
    "verify:runtime": "npm run db:verify && npm run runtime:check",
    "plugins:scan": "tsx scripts/generate-plugin-map.ts",
    "plugins:apply": "node --conditions=react-server --import tsx scripts/apply-plugin-bundle.ts",
    "plugins:check": "tsx scripts/generate-plugin-map.ts --check && tsx scripts/ploykit-plugin.ts check plugins",
    "plugins:templates": "tsx scripts/ploykit-plugin.ts check templates/plugins && tsx scripts/ploykit-plugin.ts test templates/plugins && tsx scripts/ploykit-plugin.ts build templates/plugins",
    "plugin:create": "tsx scripts/ploykit-plugin.ts create",
    "plugin:check": "tsx scripts/ploykit-plugin.ts check",
    "plugin:test": "tsx scripts/ploykit-plugin.ts test",
    "plugin:build": "tsx scripts/ploykit-plugin.ts build",
    "plugin:inspect": "tsx scripts/ploykit-plugin.ts inspect",
    "plugin:doctor": "tsx scripts/ploykit-plugin.ts doctor",
    "plugin:dev": "tsx scripts/ploykit-plugin.ts dev",
    "runtime:check": "tsx scripts/check-plugin-runtime.ts",
    "api:security-report": "tsx scripts/generate-api-security-report.ts",
    "webhooks:retry": "tsx scripts/run-webhook-retry.ts",
    "deps:check": "tsx scripts/check-dependencies.ts",
    "media:generate": "tsx scripts/generate-open-source-media.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/run-migrations.ts",
    "db:studio": "drizzle-kit studio",
    "db:verify:structure": "tsx scripts/verify-database.ts",
    "db:init": "tsx scripts/init-database.ts",
    "db:init:stripe": "tsx scripts/init-database.ts --stripe",
    "db:setup": "tsx scripts/setup-database.ts",
    "db:setup:seed": "npm run db:setup && npm run seed:tool-site",
    "db:verify": "tsx scripts/verify-migrations.ts",
    "db:docker:up": "docker compose up -d db",
    "db:docker:down": "docker compose down",
    "db:docker:reset": "docker compose down -v && docker compose up -d db",
    "db:docker:logs": "docker compose logs -f db",
    "db:docker:wait": "tsx scripts/wait-for-docker-db.ts",
    "db:docker:migrate": "tsx scripts/with-docker-db.ts -- npm run db:migrate",
    "db:docker:runtime": "tsx scripts/with-docker-db.ts -- npm run runtime:check",
    "db:docker:verify": "npm run db:verify && npm run db:docker:wait && npm run db:docker:migrate && npm run db:docker:runtime",
    "db:docker:check": "npm run db:docker:up && npm run db:docker:verify",
    "seed:tool-site": "tsx scripts/seed-tool-site.ts",
    "stripe:setup": "tsx scripts/setup-stripe-products.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:code": "npm run verify",
    "test:code:coverage": "npm run test:coverage",
    "test:real": "tsx scripts/codex-real-test.ts",
    "test:real:reset": "tsx scripts/codex-real-test.ts --reset-db",
    "test:real:prepare": "tsx scripts/codex-real-test.ts --prepare-only",
    "test:p0:failure": "tsx scripts/p0-failure-suite.ts",
    "test:workspace-scope": "tsx scripts/workspace-scope-matrix-test.ts",
    "test:stripe-provider": "tsx scripts/stripe-provider-test.ts",
    "test:storage-drivers": "tsx scripts/storage-driver-matrix-test.ts",
    "test:plugin-scale": "tsx scripts/plugin-scale-matrix-test.ts",
    "test:data-export-audit": "tsx scripts/data-export-audit-test.ts",
    "test:data-export-audit:build": "tsx scripts/data-export-audit-test.ts --build",
    "test:observability": "tsx scripts/observability-matrix-test.ts",
    "test:observability:build": "tsx scripts/observability-matrix-test.ts --build",
    "test:upgrade-migration": "tsx scripts/upgrade-migration-matrix-test.ts",
    "test:capacity": "tsx scripts/capacity-matrix-test.ts",
    "test:capacity:build": "tsx scripts/capacity-matrix-test.ts --build",
    "test:soak": "tsx scripts/soak-matrix-test.ts",
    "test:soak:build": "tsx scripts/soak-matrix-test.ts --build",
    "test:backup-restore": "tsx scripts/backup-restore-matrix-test.ts",
    "test:security-audit": "tsx scripts/security-audit-matrix-test.ts",
    "test:chaos": "tsx scripts/chaos-matrix-test.ts",
    "test:delivery-docs": "tsx scripts/delivery-docs-matrix-test.ts",
    "test:accessibility": "tsx scripts/accessibility-matrix-test.ts",
    "test:accessibility:build": "tsx scripts/accessibility-matrix-test.ts --build",
    "test:admin:catalog": "tsx scripts/check-admin-page-catalog.ts",
    "test:admin:surface": "playwright test tests/e2e/admin-surface-crawler.spec.ts",
    "test:admin:coverage": "tsx scripts/check-admin-e2e-coverage.ts",
    "test:admin:actions": "tsx scripts/check-admin-action-spec.ts",
    "test:admin:human": "npm run test:admin:catalog && npm run test:admin:surface && npm run test:admin:coverage && npm run test:admin:actions",
    "test:browser-matrix": "tsx scripts/browser-matrix-test.ts",
    "test:browser-matrix:build": "tsx scripts/browser-matrix-test.ts --build",
    "test:human": "tsx scripts/codex-real-test.ts --playwright --build",
    "test:human:headed": "tsx scripts/codex-real-test.ts --playwright --headed --build",
    "test:human:report": "playwright show-report test-results/playwright-report",
    "perf:prod": "tsx scripts/prod-perf-test.ts",
    "perf:prod:build": "tsx scripts/prod-perf-test.ts --build",
    "seo:real": "tsx scripts/seo-real-test.ts",
    "seo:real:build": "tsx scripts/seo-real-test.ts --build",
    "test:all": "npm run test:code && npm run test:real && npm run test:human",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.74.0",
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/serverless": "^0.10.4",
    "@node-rs/argon2": "^2.0.2",
    "@radix-ui/react-alert-dialog": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@xyflow/react": "^12.3.6",
    "better-auth": "^1.3.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "culori": "^4.0.2",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.6",
    "immer": "^10.1.1",
    "lucide-react": "^0.545.0",
    "nanoid": "^5.1.5",
    "next": "^16.0.8",
    "next-intl": "^4.4.0",
    "next-themes": "^0.4.6",
    "p-retry": "^7.1.0",
    "pino": "^9.5.0",
    "postgres": "^3.4.5",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.65.0",
    "recharts": "^3.2.1",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "stripe": "^17.6.0",
    "swr": "^2.3.7",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.25.76",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/culori": "^4.0.1",
    "@types/node": "^20",
    "@types/pg": "^8.11.10",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "chokidar": "^4.0.3",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9",
    "eslint-config-next": "^16.0.8",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "happy-dom": "^20.0.0",
    "iconv-lite": "^0.7.0",
    "ora": "^9.0.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.6.2",
    "tailwindcss": "^4",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
